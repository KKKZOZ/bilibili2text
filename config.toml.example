[download]
audio_quality = "30216"
output_dir = "./transcriptions"

[oss]
region = "cn-beijing"
bucket = "your-bucket-name"
access_key_id = "your-access-key-id"
access_key_secret = "your-access-key-secret"

[stt]
# 可选: "qwen" 或 "groq"
provider = "qwen"
language = "zh"

# Qwen (DashScope)
qwen_api_key = "your-dashscope-api-key"
qwen_model = "qwen3-asr-flash-filetrans"
qwen_base_url = "https://dashscope.aliyuncs.com/api/v1"

# Groq
# groq_api_key 可从 https://console.groq.com/keys 获取
groq_api_key = "your-groq-api-key"
groq_model = "whisper-large-v3-turbo"
groq_base_url = "https://api.groq.com/openai/v1"
groq_chunk_length = 1800
groq_overlap = 10
groq_bitrate = "64k"

[summarize]
profile = "dashscope"
# 仅在 qwen3 系列模型下透传到 extra_body.enable_thinking
enable_thinking = true
preset = "timeline_merge"
presets_file = "summary_presets.toml"

[summarize.profiles.openrouter]
model = "moonshotai/kimi-k2.5"
endpoint = "https://openrouter.ai/api/v1"
api_key = "your-openrouter-api-key"
# 可选：OpenRouter 路由时优先尝试的 provider（1 个或多个）
providers = ["OpenAI", "Anthropic"]

[summarize.profiles.dashscope]
model = "qwen3-max"
endpoint = "https://dashscope.aliyuncs.com/compatible-mode/v1"
api_key = "your-dashscope-api-key"

[converter]
min_length = 60
